<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - ClickSafe</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #F4F7FE; height: 100vh; display: flex; justify-content: center; align-items: center; margin: 0; }
        .login-card { background: white; padding: 50px 40px; border-radius: 24px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); width: 100%; max-width: 420px; text-align: center; }
        .logo-box { width: 50px; height: 50px; background: linear-gradient(135deg, #0EA5E9, #22C55E); border-radius: 12px; display: flex; justify-content: center; align-items: center; color: white; font-size: 24px; font-weight: bold; margin: 0 auto 20px auto; }
        .form-control { background-color: #F8FAFC; border-radius: 12px; padding: 12px; border: 1px solid #E2E8F0; margin-bottom: 15px; }
        .form-control:focus { border-color: #0EA5E9; box-shadow: 0 0 0 0.2rem rgba(14,165,233,0.25); background-color: #FFF; }
        .btn-primary { background-color: #0EA5E9; border: none; border-radius: 12px; padding: 12px; font-weight: 600; width: 100%; transition: 0.3s; }
        .btn-primary:hover { background-color: #0284C7; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo-box">C</div>
        <h3 class="mb-1 fw-bold">Welcome to ClickSafe</h3>
        <p class="text-muted mb-4 small">Cybersecurity Awareness Campaign — InfoGuard+</p>
        
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger rounded-3 small py-2"><%= error %></div>
        <% } %>
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="alert alert-success rounded-3 small py-2"><%= success %></div>
        <% } %>

        <form action="/login" method="POST" class="text-start">
            <label class="form-label small fw-semibold">Email</label>
            <input type="email" name="email" class="form-control" required>
            <label class="form-label small fw-semibold mt-2">Password</label>
            <input type="password" name="password" class="form-control" required>
            <button type="submit" class="btn btn-primary mt-4">Sign In</button>
        </form>
        
        <hr class="my-4">
        <p class="small text-muted">New here? <a href="/register" class="text-decoration-none fw-semibold" style="color:#0EA5E9;">Register as a Student or Volunteer</a></p>
    </div>
</body>
</html>
