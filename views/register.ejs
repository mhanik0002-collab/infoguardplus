<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - ClickSafe</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #F4F7FE; min-height: 100vh; display: flex; justify-content: center; align-items: center; margin: 0; padding: 40px 20px; }
        .login-card { background: white; padding: 40px; border-radius: 24px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); width: 100%; max-width: 500px; }
        .logo-box { width: 50px; height: 50px; background: linear-gradient(135deg, #0EA5E9, #22C55E); border-radius: 12px; display: flex; justify-content: center; align-items: center; color: white; font-size: 24px; font-weight: bold; margin: 0 auto 20px auto; }
        .form-control, .form-select { background-color: #F8FAFC; border-radius: 12px; padding: 10px 12px; border: 1px solid #E2E8F0; margin-bottom: 15px; font-size: 0.95rem; }
        .form-control:focus, .form-select:focus { border-color: #0EA5E9; box-shadow: 0 0 0 0.2rem rgba(14,165,233,0.25); background-color: #FFF; }
        .btn-success { background-color: #22C55E; border: none; border-radius: 12px; padding: 12px; font-weight: 600; width: 100%; transition: 0.3s; }
        .btn-success:hover { background-color: #16A34A; }
        .nav-pills .nav-link { border-radius: 10px; color: #64748B; font-weight: 500; }
        .nav-pills .nav-link.active { background-color: #0EA5E9; color: white; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="text-center">
            <div class="logo-box">C</div>
            <h3 class="mb-1 fw-bold">Join ClickSafe</h3>
            <p class="text-muted mb-4 small">Register to start learning or volunteering with InfoGuard+</p>
        </div>
        
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger rounded-3 small py-2"><%= error %></div>
        <% } %>

        <ul class="nav nav-pills nav-fill mb-4" id="roleTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="student-tab" data-bs-toggle="pill" data-bs-target="#form-content" type="button" role="tab" onclick="setRole('student')">Student</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="volunteer-tab" data-bs-toggle="pill" data-bs-target="#form-content" type="button" role="tab" onclick="setRole('volunteer')">Volunteer</button>
            </li>
        </ul>

        <form action="/register" method="POST">
            <input type="hidden" name="role" id="roleInput" value="student">
            
            <div class="row">
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">Full Name</label>
                    <input type="text" name="full_name" class="form-control" required>
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">Email</label>
                    <input type="email" name="email" class="form-control" required>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">Password</label>
                    <input type="password" name="password" class="form-control" required>
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">Phone</label>
                    <input type="text" name="phone" class="form-control" required>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">Gender</label>
                    <select name="gender" class="form-select" required>
                        <option value="">Select...</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="col-md-6" id="institutionField">
                    <label class="form-label small fw-semibold">Institution</label>
                    <input type="text" name="institution" id="institutionInput" class="form-control" placeholder="School/College/University" required>
                </div>
            </div>
            
            <div id="programField">
                <label class="form-label small fw-semibold">Select Program (Enrollment)</label>
                <select name="program_id" id="programInput" class="form-select" required>
                    <option value="">Choose a Program...</option>
                    <% if(typeof programs !== 'undefined') { programs.forEach(p => { %>
                        <option value="<%= p._id %>"><%= p.name %></option>
                    <% }) } %>
                </select>
            </div>

            <label class="form-label small fw-semibold">Address / Motivation Message</label>
            <textarea name="address" class="form-control" rows="2" placeholder="Your address... If applying as volunteer, briefly state your motivation here too!" required></textarea>

            <div id="volunteerInfo" class="alert alert-info small py-2 d-none">
                Volunteer accounts require InfoGuard+ admin approval before you can log in.
            </div>

            <button type="submit" class="btn btn-success mt-2">Create Account</button>
        </form>
        
        <hr class="my-4">
        <p class="text-center small text-muted mb-0">Already have an account? <a href="/login" class="text-decoration-none fw-semibold" style="color:#22C55E;">Sign In</a></p>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function setRole(role) {
            document.getElementById('roleInput').value = role;
            const progField = document.getElementById('programField');
            const progInput = document.getElementById('programInput');
            const instInput = document.getElementById('institutionInput');
            const volInfo = document.getElementById('volunteerInfo');

            if (role === 'volunteer') {
                progField.classList.add('d-none');
                progInput.required = false;
                instInput.required = false;
                volInfo.classList.remove('d-none');
            } else {
                progField.classList.remove('d-none');
                progInput.required = true;
                instInput.required = true;
                volInfo.classList.add('d-none');
            }
        }
    </script>
</body>
</html>
